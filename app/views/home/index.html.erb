<% tag_class = { "Workshop" => "event-card__tag--workshop", "Hybrid" => "event-card__tag--hybrid", "Social" => "event-card__tag--social" } %>

<header class="nav">
  <div class="nav__inner">
    <a href="/" class="nav__logo">
      <span class="nav__gem">◆</span>
      <span class="nav__name">Ruby Lang NYC</span>
    </a>
    <button class="nav__toggle" id="navToggle" aria-label="Toggle menu">
      <span></span><span></span><span></span>
    </button>
    <nav class="nav__links" id="navLinks">
      <a href="#companies">Companies</a>
      <a href="#events">Events</a>
      <a href="https://github.com/hackrb/ruby_lang_nyc" class="nav__cta">Contribute →</a>
    </nav>
  </div>
</header>

<section class="hero">
  <div class="hero__bg-gem" aria-hidden="true">◆</div>
  <div class="hero__inner">
    <div class="hero__eyebrow">
      <!-- <span class="hero__dot"></span> -->
      <!-- NYC Ruby Community • Est. 2018 -->
    </div>
    <h1 class="hero__title">
      <span class="hero__title-line">Mapping NYC's</span>
      <span class="hero__title-line hero__title-line--accent">Ruby Community.</span>
    </h1>
    <p class="hero__sub">
      The great big city's a wonderous gem.
    </p>
    <div class="hero__actions">
      <a href="https://github.com/hackrb/ruby_lang_nyc" class="btn btn--primary">Contribute</a>
      <a href="#events" class="btn btn--ghost">See Events ↓</a>
    </div>
    <div class="hero__stats">
      <!-- <div class="hero__stat"> -->
        <!-- <span class="hero__stat-num">400+</span> -->
        <!-- <span class="hero__stat-label">Members</span> -->
      <!-- </div> -->
      <!-- <div class="hero__stat-divider"></div> -->
      <!-- <div class="hero__stat"> -->
        <!-- <span class="hero__stat-num">52</span> -->
        <!-- <span class="hero__stat-label">Meetups</span> -->
      <!-- </div> -->
      <!-- <div class="hero__stat-divider"></div> -->
      <!-- <div class="hero__stat"> -->
        <!-- <span class="hero__stat-num">8</span> -->
        <!-- <span class="hero__stat-label">Years</span> -->
      <!-- </div> -->
    </div>
  </div>
</section>

<section class="companies" id="companies">
  <div class="companies__inner">
    <div class="companies__header">
      <h2 class="companies__title">Companies</h2>
      <p class="companies__sub">NYC companies building with Ruby.</p>
    </div>
    <div class="companies__grid">
      <% @companies.each do |company| %>
        <div class="company-card reveal">
          <div class="company-card__logo">
            <%= image_tag company[:logo_url], alt: company[:name] %>
          </div>
          <div class="company-card__right">
            <div class="company-card__body">
              <h3 class="company-card__name"><%= company[:name] %></h3>
              <p class="company-card__desc"><%= company[:description] %></p>
            </div>
            <div class="company-card__links">
              <a href="<%= company[:home_page_url] %>" class="company-card__link" target="_blank" rel="noopener noreferrer">Website →</a>
              <a href="<%= company[:careers_page_url] %>" class="company-card__link company-card__link--careers" target="_blank" rel="noopener noreferrer">Careers →</a>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>

<section class="events" id="events">
  <div class="events__inner">
    <div class="events__header">
      <h2 class="events__title">Upcoming Events</h2>
      <a href="/events" class="events__all">All events →</a>
    </div>
    <div class="events__grid">
      <% @events.each do |event| %>
        <article class="event-card reveal">
          <div class="event-card__date">
            <span class="event-card__month"><%= event[:date].strftime('%b').upcase %></span>
            <span class="event-card__day"><%= event[:date].strftime('%d') %></span>
          </div>
          <div class="event-card__body">
            <span class="event-card__tag <%= tag_class[event[:category]] %>"><%= event[:category] %></span>
            <h3 class="event-card__title"><%= event[:title] %></h3>
            <p class="event-card__location"><%= event[:location] %></p>
          </div>
        </article>
      <% end %>
    </div>
  </div>
</section>

<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <span class="nav__gem">◆</span>
      <span>Ruby Lang NYC</span>
    </div>
    <p class="footer__tagline">By Hack Ruby.</p>
    <div class="footer__links">
      <a href="https://luma.com/hackruby">Luma</a>
      <a href="https://github.com/hackrb">GitHub</a>
    </div>
    <p class="footer__copy">© 2026 Ruby Lang NYC. Built with Ruby on Rails.</p>
  </div>
</footer>

<script nonce="<%= request.content_security_policy_nonce %>">
  const toggle = document.getElementById('navToggle');
  const links  = document.getElementById('navLinks');
  toggle?.addEventListener('click', () => {
    links.classList.toggle('nav__links--open');
    toggle.classList.toggle('nav__toggle--open');
  });

  document.querySelectorAll('.hero__eyebrow, .hero__title-line, .hero__sub, .hero__actions, .hero__stats')
    .forEach((el, i) => {
      el.style.animationDelay = `${i * 0.13}s`;
      el.classList.add('hero-animate');
    });

  const io = new IntersectionObserver((entries) => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const idx = Array.from(e.target.parentNode.children).indexOf(e.target);
        e.target.style.transitionDelay = `${(idx % 3) * 0.08}s`;
        e.target.classList.add('revealed');
        io.unobserve(e.target);
      }
    });
  }, { threshold: 0.1 });
  document.querySelectorAll('.reveal').forEach(c => io.observe(c));
</script>
